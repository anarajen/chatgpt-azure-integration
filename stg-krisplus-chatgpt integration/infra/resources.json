{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.42.1.51946",
      "templateHash": "2866637874515062319"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Deployment location for environment-specific resources"
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {},
      "metadata": {
        "description": "Tags applied to environment-specific resources"
      }
    },
    "containerAppEnvironmentName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 63,
      "metadata": {
        "description": "Container Apps managed environment name"
      }
    },
    "containerAppEnvironmentExists": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Set to true when reusing an existing shared managed environment (e.g. UAT referencing the dev-created environment). When true, the managed environment is not created — only referenced."
      }
    },
    "containerAppEnvironmentResourceGroupName": {
      "type": "string",
      "defaultValue": "[resourceGroup().name]",
      "metadata": {
        "description": "Resource group name where the managed environment is located. Required when containerAppEnvironmentExists is true."
      }
    },
    "containerAppName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 63,
      "metadata": {
        "description": "Container App name"
      }
    },
    "logAnalyticsWorkspaceCustomerId": {
      "type": "string",
      "metadata": {
        "description": "Log Analytics workspace customer ID (GUID)"
      }
    },
    "logAnalyticsWorkspaceSharedKey": {
      "type": "securestring",
      "metadata": {
        "description": "Log Analytics workspace shared key"
      }
    },
    "bootstrapImage": {
      "type": "string",
      "defaultValue": "mcr.microsoft.com/azuredocs/containerapps-helloworld:latest",
      "metadata": {
        "description": "Container image to bootstrap the app. `azd deploy` will replace this with the built image."
      }
    },
    "containerPort": {
      "type": "int",
      "defaultValue": 80,
      "metadata": {
        "description": "Target container port. Default 80 matches the bootstrap image (containerapps-helloworld). CI/CD pipeline updates this to 3000 via `az containerapp update --target-port 3000` when deploying the real application image."
      }
    },
    "minReplicas": {
      "type": "int",
      "defaultValue": 0,
      "metadata": {
        "description": "Minimum replicas"
      }
    },
    "maxReplicas": {
      "type": "int",
      "defaultValue": 2,
      "metadata": {
        "description": "Maximum replicas"
      }
    },
    "cpu": {
      "type": "string",
      "defaultValue": "0.5",
      "metadata": {
        "description": "vCPU allocation per replica (string, e.g., \"0.5\")"
      }
    },
    "memory": {
      "type": "string",
      "defaultValue": "1.0Gi",
      "metadata": {
        "description": "Memory allocation per replica (string, e.g., \"1.0Gi\")"
      }
    },
    "azureSearchEndpoint": {
      "type": "string",
      "metadata": {
        "description": "Azure Search endpoint exposed to the MCP server"
      }
    },
    "azureSearchDealsIndex": {
      "type": "string",
      "metadata": {
        "description": "Azure Search deals index name"
      }
    },
    "azureSearchMerchantIndex": {
      "type": "string",
      "metadata": {
        "description": "Azure Search merchant index name"
      }
    },
    "azureSearchPrivilegeIndex": {
      "type": "string",
      "metadata": {
        "description": "Azure Search privilege index name"
      }
    },
    "viteKrisplusUniversalLink": {
      "type": "string",
      "metadata": {
        "description": "Vite Krisplus Universal Link"
      }
    },
    "widgetCspResourceDomains": {
      "type": "string",
      "metadata": {
        "description": "Widget CSP Resource Domains"
      }
    },
    "widgetCspConnectDomains": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Widget CSP Connect Domains"
      }
    },
    "widgetDomain": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Widget domain for MCP Apps sandbox (full HTTPS URL, e.g. https://myapp.example.com). Required for app submission."
      }
    },
    "staticApiUrl": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Static API URL for category data"
      }
    },
    "minScoreThreshold": {
      "type": "string",
      "defaultValue": "0.01",
      "metadata": {
        "description": "Minimum score threshold for Azure Search results"
      }
    },
    "workers": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Number of worker processes"
      }
    },
    "krisplusApiBaseUrl": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Kris+ API base URL"
      }
    },
    "krisplusCountry": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Kris+ country code"
      }
    },
    "nodeEnv": {
      "type": "string",
      "defaultValue": "production",
      "metadata": {
        "description": "Node environment"
      }
    },
    "corsAllowedOrigins": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Comma-separated list of allowed CORS origins (e.g. https://chatgpt.com). Defaults to * when empty."
      }
    },
    "infrastructureSubnetId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Resource ID of the infrastructure subnet for Container Apps VNet integration. When provided, the managed environment uses an internal load balancer (private, VNet-only). The subnet must be at least /27, must not have existing delegations, and must be delegated to Microsoft.App/environments before deployment. Leave empty to keep the current public configuration."
      }
    },
    "logAnalyticsWorkspaceResourceId": {
      "type": "string",
      "metadata": {
        "description": "Log Analytics workspace resource ID for Application Insights"
      }
    }
  },
  "variables": {
    "effectiveManagedEnvironmentId": "[if(parameters('containerAppEnvironmentExists'), format('/subscriptions/{0}/resourceGroups/{1}/providers/Microsoft.App/managedEnvironments/{2}', subscription().subscriptionId, parameters('containerAppEnvironmentResourceGroupName'), parameters('containerAppEnvironmentName')), resourceId('Microsoft.App/managedEnvironments', parameters('containerAppEnvironmentName')))]"
  },
  "resources": [
    {
      "type": "Microsoft.Insights/components",
      "apiVersion": "2020-02-02",
      "name": "[format('{0}-insights', parameters('containerAppName'))]",
      "location": "[parameters('location')]",
      "kind": "web",
      "tags": "[parameters('tags')]",
      "properties": {
        "Application_Type": "web",
        "WorkspaceResourceId": "[parameters('logAnalyticsWorkspaceResourceId')]",
        "Flow_Type": "Bluefield",
        "Request_Source": "rest",
        "RetentionInDays": 90,
        "SamplingPercentage": 100
      }
    },
    {
      "condition": "[not(parameters('containerAppEnvironmentExists'))]",
      "type": "Microsoft.App/managedEnvironments",
      "apiVersion": "2023-05-01",
      "name": "[parameters('containerAppEnvironmentName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "appLogsConfiguration": {
          "destination": "log-analytics",
          "logAnalyticsConfiguration": {
            "customerId": "[parameters('logAnalyticsWorkspaceCustomerId')]",
            "sharedKey": "[parameters('logAnalyticsWorkspaceSharedKey')]"
          }
        },
        "vnetConfiguration": "[if(not(empty(parameters('infrastructureSubnetId'))), createObject('internal', true(), 'infrastructureSubnetId', parameters('infrastructureSubnetId')), null())]"
      }
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2023-05-01",
      "name": "[parameters('containerAppName')]",
      "location": "[parameters('location')]",
      "tags": "[union(parameters('tags'), createObject('azd-service-name', 'krisplus-mcp'))]",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "managedEnvironmentId": "[variables('effectiveManagedEnvironmentId')]",
        "configuration": {
          "ingress": {
            "external": true,
            "targetPort": "[parameters('containerPort')]",
            "transport": "Http",
            "allowInsecure": false
          },
          "registries": [],
          "secrets": []
        },
        "template": {
          "containers": [
            {
              "name": "main",
              "image": "[parameters('bootstrapImage')]",
              "env": [
                {
                  "name": "AZURE_SEARCH_ENDPOINT",
                  "value": "[parameters('azureSearchEndpoint')]"
                },
                {
                  "name": "AZURE_SEARCH_DEALS_INDEX",
                  "value": "[parameters('azureSearchDealsIndex')]"
                },
                {
                  "name": "AZURE_SEARCH_MERCHANT_INDEX",
                  "value": "[parameters('azureSearchMerchantIndex')]"
                },
                {
                  "name": "AZURE_SEARCH_PRIVILEGE_INDEX",
                  "value": "[parameters('azureSearchPrivilegeIndex')]"
                },
                {
                  "name": "MIN_SCORE_THRESHOLD",
                  "value": "[parameters('minScoreThreshold')]"
                },
                {
                  "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
                  "value": "[reference(resourceId('Microsoft.Insights/components', format('{0}-insights', parameters('containerAppName'))), '2020-02-02').ConnectionString]"
                },
                {
                  "name": "WIDGET_DOMAIN",
                  "value": "[parameters('widgetDomain')]"
                },
                {
                  "name": "VITE_KRISPLUS_UNIVERSAL_LINK",
                  "value": "[parameters('viteKrisplusUniversalLink')]"
                },
                {
                  "name": "WIDGET_CSP_RESOURCE_DOMAINS",
                  "value": "[parameters('widgetCspResourceDomains')]"
                },
                {
                  "name": "WIDGET_CSP_CONNECT_DOMAINS",
                  "value": "[parameters('widgetCspConnectDomains')]"
                },
                {
                  "name": "STATIC_API_URL",
                  "value": "[parameters('staticApiUrl')]"
                },
                {
                  "name": "KRISPLUS_API_BASE_URL",
                  "value": "[parameters('krisplusApiBaseUrl')]"
                },
                {
                  "name": "KRISPLUS_COUNTRY",
                  "value": "[parameters('krisplusCountry')]"
                },
                {
                  "name": "PORT",
                  "value": "[string(parameters('containerPort'))]"
                },
                {
                  "name": "NODE_ENV",
                  "value": "[parameters('nodeEnv')]"
                },
                {
                  "name": "CORS_ALLOWED_ORIGINS",
                  "value": "[parameters('corsAllowedOrigins')]"
                },
                {
                  "name": "WORKERS",
                  "value": "[parameters('workers')]"
                }
              ],
              "probes": [],
              "resources": {
                "cpu": "[json(parameters('cpu'))]",
                "memory": "[parameters('memory')]"
              }
            }
          ],
          "scale": {
            "minReplicas": "[parameters('minReplicas')]",
            "maxReplicas": "[parameters('maxReplicas')]",
            "rules": [
              {
                "name": "http-concurrency-rule",
                "http": {
                  "metadata": {
                    "concurrentRequests": "10"
                  }
                }
              },
              {
                "name": "cpu-utilization-rule",
                "custom": {
                  "type": "cpu",
                  "metadata": {
                    "type": "Utilization",
                    "value": "70"
                  }
                }
              },
              {
                "name": "memory-utilization-rule",
                "custom": {
                  "type": "memory",
                  "metadata": {
                    "type": "Utilization",
                    "value": "75"
                  }
                }
              }
            ]
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Insights/components', format('{0}-insights', parameters('containerAppName')))]",
        "[resourceId('Microsoft.App/managedEnvironments', parameters('containerAppEnvironmentName'))]"
      ]
    }
  ],
  "outputs": {
    "CONTAINER_APP_FQDN": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.App/containerApps', parameters('containerAppName')), '2023-05-01').configuration.ingress.fqdn]"
    },
    "CONTAINER_APP_RESOURCE_ID": {
      "type": "string",
      "value": "[resourceId('Microsoft.App/containerApps', parameters('containerAppName'))]"
    },
    "CONTAINER_APP_PRINCIPAL_ID": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.App/containerApps', parameters('containerAppName')), '2023-05-01', 'full').identity.principalId]"
    },
    "MANAGED_ENVIRONMENT_DEFAULT_DOMAIN": {
      "type": "string",
      "value": "[if(parameters('containerAppEnvironmentExists'), reference(variables('effectiveManagedEnvironmentId'), '2023-05-01').defaultDomain, reference(resourceId('Microsoft.App/managedEnvironments', parameters('containerAppEnvironmentName')), '2023-05-01').defaultDomain)]"
    },
    "MANAGED_ENVIRONMENT_STATIC_IP": {
      "type": "string",
      "value": "[if(parameters('containerAppEnvironmentExists'), reference(variables('effectiveManagedEnvironmentId'), '2023-05-01').staticIp, reference(resourceId('Microsoft.App/managedEnvironments', parameters('containerAppEnvironmentName')), '2023-05-01').staticIp)]"
    },
    "APPLICATION_INSIGHTS_CONNECTION_STRING": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Insights/components', format('{0}-insights', parameters('containerAppName'))), '2020-02-02').ConnectionString]"
    },
    "APPLICATION_INSIGHTS_INSTRUMENTATION_KEY": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Insights/components', format('{0}-insights', parameters('containerAppName'))), '2020-02-02').InstrumentationKey]"
    },
    "APPLICATION_INSIGHTS_RESOURCE_ID": {
      "type": "string",
      "value": "[resourceId('Microsoft.Insights/components', format('{0}-insights', parameters('containerAppName')))]"
    }
  }
}